<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>AZTEC BET</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <style>
        *{margin:0;padding:0;box-sizing:border-box}
        body{background:#1a1a2e;color:white;font-family:system-ui;padding:20px}
        .btn{display:block;width:100%;padding:15px;margin:10px 0;border-radius:15px;font-size:18px;font-weight:bold;border:none;cursor:pointer}
        .deposit{background:#2ecc71;color:white}
        .withdraw{background:#e74c3c;color:white}
        .balance{font-size:36px;color:#ffd700;text-align:center;margin:20px 0}
    </style>
</head>
<body>
    <h1 style="text-align:center">🎰 AZTEC BET</h1>
    <div class="balance" id="balance">0 TON</div>
    <button class="btn deposit" id="depositBtn">💎 ПОПОЛНИТЬ</button>
    <button class="btn withdraw" id="withdrawBtn">💸 ВЫВЕСТИ</button>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        
        document.getElementById('depositBtn').onclick = function() {
            tg.sendData(JSON.stringify({ action: 'deposit' }));
        };
        
        document.getElementById('withdrawBtn').onclick = function() {
            tg.sendData(JSON.stringify({ action: 'withdraw' }));
        };
        
        tg.sendData(JSON.stringify({ action: 'check_balance' }));
    </script>
</body>
</html>