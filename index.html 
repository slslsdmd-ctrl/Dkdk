<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
    <title>AZTEC BET</title>
    <script src="https://telegram.org/js/telegram-web-app.js"></script>
    <script src="https://unpkg.com/@tonconnect/sdk@latest/dist/index.js"></script>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
            user-select: none;
            -webkit-tap-highlight-color: transparent;
        }

        body {
            background: linear-gradient(135deg, #0a0a0a 0%, #1a1a2e 100%);
            font-family: system-ui, -apple-system, 'Segoe UI', sans-serif;
            color: white;
            min-height: 100vh;
            padding-bottom: 30px;
        }

        .container {
            max-width: 500px;
            margin: 0 auto;
            padding: 20px;
        }

        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        @keyframes winGlow {
            0% { text-shadow: 0 0 0px gold; }
            50% { text-shadow: 0 0 20px gold; }
            100% { text-shadow: 0 0 0px gold; }
        }

        .animate-fade { animation: fadeIn 0.5s ease; }
        .win-animation { animation: winGlow 0.5s ease; }

        .balance-card {
            background: linear-gradient(135deg, #1e2a3a 0%, #0f172a 100%);
            border-radius: 25px;
            padding: 20px;
            text-align: center;
            box-shadow: 0 10px 30px rgba(0,0,0,0.3);
            border: 1px solid rgba(255,215,0,0.2);
            margin-bottom: 25px;
        }

        .balance-value {
            font-size: 48px;
            font-weight: bold;
            color: #ffd700;
            margin: 5px 0;
        }

        .balance-label {
            font-size: 14px;
            color: #aaa;
            letter-spacing: 2px;
        }

        .btn {
            display: block;
            width: 100%;
            padding: 15px;
            margin: 10px 0;
            border-radius: 15px;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            border: none;
            transition: all 0.3s ease;
        }

        .btn:active {
            transform: scale(0.97);
        }

        .btn-deposit {
            background: linear-gradient(135deg, #2ecc71, #27ae60);
            color: white;
        }

        .btn-withdraw {
            background: linear-gradient(135deg, #e74c3c, #c0392b);
            color: white;
        }

        .btn-wallet {
            background: linear-gradient(135deg, #3498db, #2980b9);
            color: white;
        }

        .games-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-top: 20px;
        }

        .game-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(10px);
            border-radius: 20px;
            padding: 20px 10px;
            text-align: center;
            cursor: pointer;
            transition: all 0.3s ease;
            border: 1px solid rgba(255,215,0,0.2);
        }

        .game-card:active {
            transform: scale(0.95);
            background: rgba(255,255,255,0.1);
        }

        .game-emoji {
            font-size: 48px;
            margin-bottom: 10px;
        }

        .game-name {
            font-size: 14px;
        }

        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.95);
            z-index: 1000;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(5px);
        }

        .modal-content {
            background: linear-gradient(135deg, #16213e 0%, #0f0f23 100%);
            border-radius: 30px;
            width: 90%;
            max-width: 400px;
            border: 1px solid rgba(255,215,0,0.3);
            animation: fadeIn 0.3s ease;
        }

        .modal-header {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .modal-header h3 {
            color: #ffd700;
        }

        .close-btn {
            background: none;
            border: none;
            color: white;
            font-size: 28px;
            cursor: pointer;
        }

        .modal-body {
            padding: 20px;
        }

        .bet-input {
            width: 100%;
            padding: 12px;
            border-radius: 15px;
            border: 1px solid rgba(255,215,0,0.3);
            background: rgba(255,255,255,0.1);
            color: white;
            font-size: 16px;
            margin: 10px 0;
            text-align: center;
        }

        .choice-buttons {
            display: flex;
            gap: 10px;
            margin: 20px 0;
            flex-wrap: wrap;
        }

        .choice-btn {
            flex: 1;
            padding: 12px;
            background: rgba(255,215,0,0.2);
            border: 1px solid #ffd700;
            border-radius: 15px;
            color: white;
            font-size: 16px;
            cursor: pointer;
            text-align: center;
        }

        .spin-btn {
            background: linear-gradient(135deg, #f39c12, #e67e22);
            border: none;
            padding: 15px;
            border-radius: 30px;
            color: white;
            font-size: 18px;
            font-weight: bold;
            cursor: pointer;
            width: 100%;
            margin-top: 15px;
        }

        .result-text {
            font-size: 18px;
            text-align: center;
            padding: 15px;
            border-radius: 15px;
            margin-top: 15px;
        }

        .win {
            background: rgba(46,204,113,0.3);
            color: #2ecc71;
        }

        .lose {
            background: rgba(231,76,60,0.3);
            color: #e74c3c;
        }

        .draw {
            background: rgba(241,196,15,0.3);
            color: #f1c40f;
        }

        .footer {
            text-align: center;
            margin-top: 30px;
            padding: 15px;
            font-size: 12px;
            color: #666;
        }
    </style>
</head>
<body>
    <div class="container animate-fade">
        <div class="balance-card">
            <div class="balance-label">💰 БАЛАНС</div>
            <div class="balance-value" id="balance">0</div>
            <div class="balance-label">TON</div>
        </div>

        <button class="btn btn-deposit" id="depositBtn">💎 ПОПОЛНИТЬ</button>
        <button class="btn btn-withdraw" id="withdrawBtn">💸 ВЫВЕСТИ</button>
        <button class="btn btn-wallet" id="walletBtn">🔗 TON CONNECT</button>

        <div class="games-grid">
            <div class="game-card" data-game="coin"><div class="game-emoji">🪙</div><div class="game-name">Монетка</div></div>
            <div class="game-card" data-game="number"><div class="game-emoji">🔢</div><div class="game-name">Число</div></div>
            <div class="game-card" data-game="dice"><div class="game-emoji">🎲</div><div class="game-name">Кости</div></div>
            <div class="game-card" data-game="slot"><div class="game-emoji">🎰</div><div class="game-name">Слоты</div></div>
            <div class="game-card" data-game="roulette"><div class="game-emoji">🎡</div><div class="game-name">Рулетка</div></div>
            <div class="game-card" data-game="rps"><div class="game-emoji">✂️</div><div class="game-name">КНБ</div></div>
        </div>

        <div class="footer">AZTEC BET</div>
    </div>

    <div class="modal" id="gameModal">
        <div class="modal-content">
            <div class="modal-header">
                <h3 id="gameTitle">Игра</h3>
                <button class="close-btn" id="closeGameModal">&times;</button>
            </div>
            <div class="modal-body" id="gameContent"></div>
        </div>
    </div>

    <script>
        const tg = window.Telegram.WebApp;
        tg.expand();
        tg.ready();

        let currentBalance = 0;

        // ========== НАСТРОЙКИ TON CONNECT ==========
        const manifestUrl = 'https://raw.githubusercontent.com/slslsdmd-ctrl/Dkdk/main/tonconnect-manifest.json';
        let connector = null;
        let walletConnected = false;

        // Функция инициализации TON Connect
        async function initTonConnect() {
            try {
                connector = new TonConnectSDK.TonConnect({ manifestUrl });
                // Проверяем, есть ли сохранённое подключение
                const savedConnection = localStorage.getItem('tonconnect-storage');
                if (savedConnection) {
                    const connection = JSON.parse(savedConnection);
                    if (connection && connection.connected) {
                        walletConnected = true;
                        console.log('Кошелёк уже подключён');
                    }
                }
            } catch (e) {
                console.error('TON Connect ошибка:', e);
            }
        }

        // Подключение кошелька
        async function connectWallet() {
            try {
                const wallets = await connector.getWallets();
                if (wallets.length === 0) {
                    tg.showPopup({ title: 'Ошибка', message: 'Установите Tonkeeper или другой TON кошелёк' });
                    return;
                }
                
                const tonkeeper = wallets.find(w => w.name === 'Tonkeeper') || wallets[0];
                const link = connector.connect({ bridgeUrl: tonkeeper.bridgeUrl, universalLink: tonkeeper.universalLink });
                
                // Открываем ссылку для подключения
                tg.openTelegramLink(link);
                
                // Ожидаем подтверждения
                const connected = await connector.restoreConnection();
                if (connected) {
                    walletConnected = true;
                    localStorage.setItem('tonconnect-storage', JSON.stringify({ connected: true }));
                    tg.showPopup({ title: 'Успех', message: 'Кошелёк успешно подключён!' });
                }
            } catch (e) {
                console.error('Ошибка подключения:', e);
                tg.showPopup({ title: 'Ошибка', message: 'Не удалось подключить кошелёк' });
            }
        }

        // Отправка платежа через TON Connect
        async function sendPayment(amount) {
            if (!walletConnected) {
                await connectWallet();
                return;
            }
            
            try {
                const transaction = {
                    validUntil: Math.floor(Date.now() / 1000) + 600,
                    messages: [{
                        address: "UQCvOIAt2X1PHfquND-LxzVYg0Gl3a_IExORwwPjowI3Nkb8",
                        amount: amount.toString(),
                        payload: ""
                    }]
                };
                
                const result = await connector.sendTransaction(transaction);
                if (result) {
                    tg.sendData(JSON.stringify({ action: 'deposit_complete', amount: amount / 1e9 }));
                    tg.showPopup({ title: 'Оплачено', message: `${amount / 1e9} TON успешно зачислено!` });
                }
            } catch (e) {
                console.error('Ошибка платежа:', e);
                tg.showPopup({ title: 'Ошибка', message: 'Платёж не выполнен' });
            }
        }

        // Открыть модалку пополнения
        function openDepositModal() {
            const amount = prompt('Введите сумму пополнения в TON:', '1');
            if (amount && !isNaN(amount) && parseFloat(amount) >= 0.1) {
                sendPayment(parseFloat(amount) * 1e9);
            } else {
                tg.showPopup({ title: 'Ошибка', message: 'Введите сумму от 0.1 TON' });
            }
        }

        function updateBalanceDisplay(value) {
            currentBalance = value;
            document.getElementById('balance').textContent = currentBalance;
            const el = document.getElementById('balance');
            el.classList.add('win-animation');
            setTimeout(() => el.classList.remove('win-animation'), 500);
        }

        function showResult(message, type) {
            const gameContent = document.getElementById('gameContent');
            const resultDiv = document.createElement('div');
            resultDiv.className = `result-text ${type}`;
            resultDiv.textContent = message;
            gameContent.appendChild(resultDiv);
            setTimeout(() => resultDiv.remove(), 2500);
        }

        // ========== МОНЕТКА ==========
        function playCoin() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            const choice = document.querySelector('input[name="choice"]:checked').value;
            const result = Math.random() < 0.5 ? 'орел' : 'решка';
            const win = choice === result;
            const amount = win ? bet * 2 : -bet;
            showResult(win ? `🎉 ПОБЕДА! +${amount} TON (${result})` : `😢 ПРОИГРЫШ! -${bet} TON (${result})`, win ? 'win' : 'lose');
            tg.sendData(JSON.stringify({ action: 'game_result', game: 'coin', win: win, amount: amount }));
        }

        // ========== УГАДАЙ ЧИСЛО ==========
        function playNumber() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            const guess = parseInt(document.getElementById('selectedNumber').value);
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            const result = Math.floor(Math.random() * 10) + 1;
            const win = guess === result;
            const amount = win ? bet * 3 : -bet;
            showResult(win ? `🎉 ПОБЕДА! +${amount} TON (было ${result})` : `😢 ПРОИГРЫШ! -${bet} TON (было ${result})`, win ? 'win' : 'lose');
            tg.sendData(JSON.stringify({ action: 'game_result', game: 'number', win: win, amount: amount }));
        }

        // ========== КОСТИ ==========
        function playDice() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            const choice = document.querySelector('input[name="diceChoice"]:checked').value;
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            const d1 = Math.floor(Math.random() * 6) + 1;
            const d2 = Math.floor(Math.random() * 6) + 1;
            const sum = d1 + d2;
            let win = false, amount = -bet, msg = '';

            if (choice === 'sum') {
                const guess = parseInt(document.getElementById('diceSum').value);
                if (guess === sum) { win = true; amount = bet * 3; msg = `🎉 ПОБЕДА! ${d1}+${d2}=${sum} +${amount} TON`; }
                else { msg = `😢 ПРОИГРЫШ! ${d1}+${d2}=${sum} -${bet} TON`; }
            } else if (choice === 'over') {
                if (sum > 7) { win = true; amount = bet * 2; msg = `🎉 ПОБЕДА! ${d1}+${d2}=${sum} +${amount} TON`; }
                else if (sum < 7) { msg = `😢 ПРОИГРЫШ! ${d1}+${d2}=${sum} -${bet} TON`; }
                else { msg = `😐 НИЧЬЯ! ${d1}+${d2}=7`; amount = 0; }
            } else {
                const isEven = sum % 2 === 0;
                if ((choice === 'even' && isEven) || (choice === 'odd' && !isEven)) { win = true; amount = bet * 2; msg = `🎉 ПОБЕДА! ${d1}+${d2}=${sum} +${amount} TON`; }
                else { msg = `😢 ПРОИГРЫШ! ${d1}+${d2}=${sum} -${bet} TON`; }
            }
            showResult(msg, win ? 'win' : (amount === 0 ? 'draw' : 'lose'));
            tg.sendData(JSON.stringify({ action: 'game_result', game: 'dice', win: win, amount: amount }));
        }

        // ========== СЛОТЫ ==========
        let spinning = false;
        function playSlot() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            if (spinning) return;
            spinning = true;
            const symbols = ['🍒', '🍋', '🍊', '🍉', '💎', '7️⃣', '⭐', '🎰'];
            const reels = [document.getElementById('slot1'), document.getElementById('slot2'), document.getElementById('slot3')];
            let spins = 0;
            const interval = setInterval(() => {
                reels.forEach(r => r.textContent = symbols[Math.floor(Math.random() * symbols.length)]);
                spins++;
                if (spins >= 10) {
                    clearInterval(interval);
                    const s1 = reels[0].textContent, s2 = reels[1].textContent, s3 = reels[2].textContent;
                    let mult = 0;
                    if (s1 === s2 && s2 === s3) {
                        if (s1 === '7️⃣' || s1 === '💎' || s1 === '🎰') mult = 5;
                        else if (s1 === '🍉') mult = 4;
                        else if (s1 === '🍒' || s1 === '🍋' || s1 === '🍊') mult = 3;
                        else if (s1 === '⭐') mult = 2;
                    }
                    const win = mult > 0;
                    const amount = win ? bet * mult : -bet;
                    showResult(win ? `🎉 ВЫИГРЫШ! +${amount} TON` : `😢 ПРОИГРЫШ! -${bet} TON`, win ? 'win' : 'lose');
                    tg.sendData(JSON.stringify({ action: 'game_result', game: 'slot', win: win, amount: amount }));
                    spinning = false;
                }
            }, 80);
        }

        // ========== РУЛЕТКА ==========
        function playRoulette() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            const choice = document.querySelector('input[name="rouletteChoice"]:checked').value;
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            const num = Math.floor(Math.random() * 37);
            const red = [1,3,5,7,9,12,14,16,18,19,21,23,25,27,30,32,34,36];
            const black = [2,4,6,8,10,11,13,15,17,20,22,24,26,28,29,31,33,35];
            let win = false, amount = -bet, msg = '';

            if (choice === 'red') {
                if (red.includes(num)) { win = true; amount = bet * 2; msg = `🎉 ПОБЕДА! ${num} +${amount} TON`; }
                else { msg = `😢 ПРОИГРЫШ! ${num} -${bet} TON`; }
            } else if (choice === 'black') {
                if (black.includes(num)) { win = true; amount = bet * 2; msg = `🎉 ПОБЕДА! ${num} +${amount} TON`; }
                else { msg = `😢 ПРОИГРЫШ! ${num} -${bet} TON`; }
            } else {
                const guess = parseInt(document.getElementById('rouletteNum').value);
                if (guess === num) { win = true; amount = bet * 36; msg = `🎉 ДЖЕКПОТ! ${num} +${amount} TON`; }
                else { msg = `😢 ПРОИГРЫШ! ${num} -${bet} TON`; }
            }
            showResult(msg, win ? 'win' : 'lose');
            tg.sendData(JSON.stringify({ action: 'game_result', game: 'roulette', win: win, amount: amount }));
        }

        // ========== КНБ ==========
        function playRPS() {
            const bet = parseFloat(document.getElementById('betAmount').value);
            const choice = document.querySelector('input[name="rpsChoice"]:checked').value;
            if (isNaN(bet) || bet < 0.1) {
                tg.showPopup({ title: 'Ошибка', message: 'Введите ставку от 0.1 TON' });
                return;
            }
            if (bet > currentBalance) {
                tg.showPopup({ title: 'Ошибка', message: 'Недостаточно средств!' });
                return;
            }
            const choices = ['rock', 'scissors', 'paper'];
            const bot = choices[Math.floor(Math.random() * 3)];
            const names = { rock: '🪨', scissors: '✂️', paper: '📄' };
            let win = false, amount = -bet, msg = '';

            if (choice === bot) { amount = 0; msg = `😐 НИЧЬЯ! ${names[choice]} vs ${names[bot]}`; }
            else if ((choice === 'rock' && bot === 'scissors') || (choice === 'scissors' && bot === 'paper') || (choice === 'paper' && bot === 'rock')) {
                win = true; amount = bet * 2; msg = `🎉 ПОБЕДА! +${amount} TON`;
            } else { msg = `😢 ПРОИГРЫШ! -${bet} TON`; }
            showResult(msg, win ? 'win' : (amount === 0 ? 'draw' : 'lose'));
            tg.sendData(JSON.stringify({ action: 'game_result', game: 'rps', win: win, amount: amount }));
        }

        // ========== ОТКРЫТЬ ИГРУ ==========
        function openGame(game) {
            const modal = document.getElementById('gameModal');
            const gameTitle = document.getElementById('gameTitle');
            const gameContent = document.getElementById('gameContent');
            let html = '';

            if (game === 'coin') {
                gameTitle.textContent = '🪙 Монетка';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><div class="choice-buttons"><label class="choice-btn"><input type="radio" name="choice" value="орел" checked> 🪨 ОРЕЛ</label><label class="choice-btn"><input type="radio" name="choice" value="решка"> 📄 РЕШКА</label></div><button class="spin-btn" onclick="playCoin()">СДЕЛАТЬ СТАВКУ</button></div>`;
            } else if (game === 'number') {
                let btns = '';
                for (let i = 1; i <= 10; i++) {
                    btns += `<button class="choice-btn" style="flex:auto;width:18%" onclick="document.querySelectorAll('.num-btn').forEach(b=>b.style.background='rgba(255,215,0,0.2)'); this.style.background='#ffd700'; document.getElementById('selectedNumber').value=${i}">${i}</button>`;
                }
                gameTitle.textContent = '🔢 Угадай число';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><input type="hidden" id="selectedNumber" value="1"><div class="choice-buttons" style="display:flex;flex-wrap:wrap;gap:5px">${btns}</div><button class="spin-btn" onclick="playNumber()">СДЕЛАТЬ СТАВКУ</button></div>`;
            } else if (game === 'dice') {
                gameTitle.textContent = '🎲 Кости';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><div class="choice-buttons"><label class="choice-btn"><input type="radio" name="diceChoice" value="sum" checked> СУММА</label><label class="choice-btn"><input type="radio" name="diceChoice" value="over"> >7 / <7</label><label class="choice-btn"><input type="radio" name="diceChoice" value="even"> ЧЁТ/НЕЧЕТ</label></div><div id="diceExtra"><input type="number" id="diceSum" class="bet-input" placeholder="Сумма (2-12)" min="2" max="12"></div><button class="spin-btn" onclick="playDice()">СДЕЛАТЬ СТАВКУ</button></div>`;
            } else if (game === 'slot') {
                gameTitle.textContent = '🎰 Слоты';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><div class="slot-reels" style="display:flex;justify-content:center;gap:15px;margin:20px 0"><div class="slot-reel" style="font-size:48px;background:rgba(0,0,0,0.5);padding:15px;border-radius:15px" id="slot1">🍒</div><div class="slot-reel" id="slot2">🍒</div><div class="slot-reel" id="slot3">🍒</div></div><button class="spin-btn" onclick="playSlot()">ЗАПУСТИТЬ</button></div>`;
            } else if (game === 'roulette') {
                gameTitle.textContent = '🎡 Рулетка';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><div class="choice-buttons"><label class="choice-btn"><input type="radio" name="rouletteChoice" value="red" checked> 🔴 КРАСНОЕ</label><label class="choice-btn"><input type="radio" name="rouletteChoice" value="black"> ⚫ ЧЁРНОЕ</label><label class="choice-btn"><input type="radio" name="rouletteChoice" value="number"> 🔢 ЧИСЛО</label></div><div id="rouletteExtra"></div><button class="spin-btn" onclick="playRoulette()">СДЕЛАТЬ СТАВКУ</button></div>`;
            } else if (game === 'rps') {
                gameTitle.textContent = '✂️ КНБ';
                html = `<div><input type="number" id="betAmount" class="bet-input" placeholder="Ставка в TON" step="0.1" min="0.1"><div class="choice-buttons"><label class="choice-btn"><input type="radio" name="rpsChoice" value="rock" checked> 🪨 КАМЕНЬ</label><label class="choice-btn"><input type="radio" name="rpsChoice" value="scissors"> ✂️ НОЖНИЦЫ</label><label class="choice-btn"><input type="radio" name="rpsChoice" value="paper"> 📄 БУМАГА</label></div><button class="spin-btn" onclick="playRPS()">СДЕЛАТЬ СТАВКУ</button></div>`;
            }

            gameContent.innerHTML = html;
            modal.style.display = 'flex';

            setTimeout(() => {
                document.querySelectorAll('input[name="diceChoice"]').forEach(r => {
                    r.onchange = () => {
                        const extra = document.getElementById('diceExtra');
                        if (r.value === 'sum') extra.innerHTML = '<input type="number" id="diceSum" class="bet-input" placeholder="Сумма (2-12)" min="2" max="12">';
                        else extra.innerHTML = '';
                    };
                });
                document.querySelectorAll('input[name="rouletteChoice"]').forEach(r => {
                    r.onchange = () => {
                        const extra = document.getElementById('rouletteExtra');
                        if (r.value === 'number') extra.innerHTML = '<input type="number" id="rouletteNum" class="bet-input" placeholder="Число (0-36)" min="0" max="36">';
                        else extra.innerHTML = '';
                    };
                });
            }, 10);
        }

        // Инициализация
        initTonConnect();

        document.getElementById('depositBtn').onclick = () => openDepositModal();
        document.getElementById('withdrawBtn').onclick = () => tg.sendData(JSON.stringify({ action: 'withdraw' }));
        document.getElementById('walletBtn').onclick = () => connectWallet();

        document.querySelectorAll('.game-card').forEach(card => {
            card.onclick = () => openGame(card.dataset.game);
        });

        document.getElementById('closeGameModal').onclick = () => document.getElementById('gameModal').style.display = 'none';
        window.onclick = (e) => {
            if (e.target === document.getElementById('gameModal')) document.getElementById('gameModal').style.display = 'none';
        };

        tg.sendData(JSON.stringify({ action: 'check_balance' }));
    </script>
</body>
</html>