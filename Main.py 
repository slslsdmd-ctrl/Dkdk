            f"📦 Адрес: `{wallet}`\n"
            f"⏱ Время вывода: до 72 часов",
            parse_mode="Markdown"
        )
        
        await context.bot.send_message(
            ADMIN_ID,
            f"📝 **НОВАЯ ЗАЯВКА НА ВЫВОД**\n\n"
            f"🆔 ID: {rid}\n"
            f"👤 Пользователь: {uid}\n"
            f"💰 Сумма: {amount} TON\n"
            f"📦 Кошелёк: `{wallet}`",
