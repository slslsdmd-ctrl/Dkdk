            try:
                await context.bot.send_message(ref, f"🎉 +0.1 TON! {name} перешёл по твоей ссылке!")
            except:
                pass
    
    await update.message.reply_text(get_text(uid, 'welcome', CASINO_NAME, name, round_ton(users[uid]['balance'])), reply_markup=main_menu(uid))

